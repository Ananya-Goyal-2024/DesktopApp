{
  "name": "p2p-office",
  "version": "0.1.0",
  "description": "Strictly peer-to-peer office communication: chat, files, images and video with no central server. Built on the Holepunch stack with an Autobase trust ledger.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check backend/p2p.js",
    "build": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "autobase": "^7.5.0",
    "b4a": "^1.6.6",
    "blind-pairing": "^2.3.1",
    "corestore": "^7.0.0",
    "hyperbee": "^2.20.0",
    "hypercore-crypto": "^3.4.0",
    "hyperdrive": "^13.0.0",
    "hyperswarm": "^4.8.0",
    "sodium-native": "^5.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^31.7.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.example.p2poffice",
    "productName": "P2P Office",
    "files": [
      "main.js",
      "preload.js",
      "backend/**/*",
      "renderer/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
